@article{bohorquez_desarrollo_2024,
	title = {Desarrollo de una metodología para el análisis de la información del proceso de {RIPS} en el sector salud},
	url = {https://dspace.tdea.edu.co/handle/tdea/5830},
	abstract = {Este estudio se centra en el desarrollo de 'RIPS Inspector', una metodología diseñada para identificar errores en los Registros Individuales de Prestación de Servicios de Salud (RIPS) en Colombia. Enmarcado en un contexto donde la calidad de los datos es fundamental dentro de los sistemas de información del sector salud en Colombia, resaltando la importancia de contar con registros fiables y exactos con el fin de ser utilizados en estudios y análisis descriptivos.

Es así que 'RIPS Inspector' aplica un enfoque estructurado y específico para la identificación de posibles errores en los datos de los RIPS. Diseñada para adaptarse a diferentes contextos y necesidades del sistema de salud, esta herramienta demuestra ser particularmente útil y flexible. Los hallazgos del estudio revelan la eficiencia de 'RIPS Inspector' en detectar errores, contribuyendo significativamente a la mejora de la calidad de los datos en el ámbito de la salud.

El trabajo destaca la relevancia de 'RIPS Inspector' en el actual panorama del sector salud en Colombia, enfatizando su potencial para optimizar la gestión de datos de salud y fortalecer la toma de decisiones basada en información precisa. A pesar de enfrentar desafíos como la integración en sistemas existentes y la variabilidad en la calidad inicial de los datos, estos aspectos resaltan la necesidad de una continua evolución en este campo. En conclusión, se recomienda emplear 'RIPS Inspector' como una guía adaptable y flexible, subrayando la importancia de personalizar su aplicación según las necesidades específicas de cada contexto de implementación.},
	language = {spa},
	urldate = {2026-03-23},
	publisher = {Tecnológico de Antioquia, Institución Universitaria},
	author = {Bohórquez},
	month = may,
	year = {2024},
	file = {Full Text PDF:/home/andres-crow/Zotero/storage/R89DALH7/Bohórquez - 2024 - Desarrollo de una metodología para el análisis de la información del proceso de RIPS en el sector sa.pdf:application/pdf},
}

@article{medrano_caracterizacion_2015,
